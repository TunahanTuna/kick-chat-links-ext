{
  "manifest_version": 3,
  "name": "Kick Chat Links Extension",
  "version": "1.0.0",
  "description": "Displays Kick chat links directly inside the streamer dashboard.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.kick.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://dashboard.kick.com/*", "*://kick.com/*"],
      "js": ["src/content.tsx"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
